# Google Maps Platform API Keys
# Main API Key (enable: Geocoding, Places, Routes APIs)
GOOGLE_API_KEY=your_google_api_key_here

# Separate API Key for Address Validation (enable: Address Validation API)
GOOGLE_ADDRESS_VALIDATION_API_KEY=your_google_address_validation_key_here

# Twilio Configuration (for OTP SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
# Set to 'true' to send actual SMS, 'false' to only log OTPs to console (useful for development)
TWILIO_SMS_ENABLED=false

# OTP Configuration
OTP_LENGTH=4
OTP_MAX_ATTEMPTS=3
OTP_EXPIRY_MINUTES=30
OTP_LOCKOUT_MINUTES=15

# Test Data Configuration (for seed script)
TEST_PHONE_NUMBER=9767996768
