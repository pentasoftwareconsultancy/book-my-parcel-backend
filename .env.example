# =============================================================================
# BMP-Backend — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# All values here are placeholders — no real credentials should appear in this file.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
# API is available at both /api (legacy) and /api/v1 (versioned)
# Frontend should migrate to /api/v1 over time

# Comma-separated list of allowed frontend origins for CORS.
# In production, set this to your actual frontend URL(s).
# Example: ALLOWED_ORIGINS=https://myapp.com,https://staging.myapp.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long, random string (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_SSL=false

# Optional: full connection URL (overrides individual DB_* vars if set)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for BullMQ notification queue. Leave blank to disable queued notifications.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_URL=redis://localhost:6379

# ── Google Maps Platform ──────────────────────────────────────────────────────
# Create API keys at: https://console.cloud.google.com/apis/credentials
# Restrict each key to only the APIs it needs and to your server's IP.

# Main key — enable: Geocoding API, Places API, Routes API
GOOGLE_API_KEY=your_google_api_key_here

# Address Validation key — enable: Address Validation API
GOOGLE_ADDRESS_VALIDATION_API_KEY=your_google_address_validation_key_here

# Individual service keys (can reuse main key if APIs are enabled on it)
GOOGLE_ROUTES_API=your_google_routes_api_key_here
GOOGLE_DISTANCE_MATRIX_API=your_google_distance_matrix_api_key_here
GOOGLE_GEOCODING_API=your_google_geocoding_api_key_here
GOOGLE_GEOLOCATION_KEY=your_google_geolocation_key_here

# ── Payment Gateway (Razorpay) ────────────────────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_*) for development, live keys (rzp_live_*) for production.
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ── Twilio (OTP SMS + WhatsApp notifications) ─────────────────────────────────
# Get credentials from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Set to 'true' to send real SMS. 'false' logs OTPs to console only (safe for dev).
TWILIO_SMS_ENABLED=false
# Trial mode: Twilio free trial can only send to verified numbers.
# Set to 'true' to redirect ALL SMS/WhatsApp to TEST_PHONE_NUMBER.
# Set to 'false' in production when you have a paid account.
TWILIO_TRIAL_MODE=true
# WhatsApp sandbox sender (get from Twilio console → Messaging → Try WhatsApp)
TWILIO_WHATSAPP_ENABLED=false
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── OTP Configuration ─────────────────────────────────────────────────────────
OTP_LENGTH=4
OTP_MAX_ATTEMPTS=3
OTP_EXPIRY_MINUTES=30
OTP_LOCKOUT_MINUTES=15

# ── Firebase (FCM Push Notifications) ────────────────────────────────────────
# Paste the entire service account JSON as a single-line string.
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"YOUR_PROJECT_ID",...}

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Works with Gmail, SendGrid, Mailgun, or any SMTP provider.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password.
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=<api_key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_NAME=Book My Parcel

# ── WhatsApp (Twilio WhatsApp API) ────────────────────────────────────────────
# Uses the same Twilio account as OTP SMS.
# Sandbox sender: whatsapp:+14155238886 (for testing)
# Production: use your approved WhatsApp Business number.
# Set to 'true' to send real messages. 'false' logs only (safe for dev).
TWILIO_WHATSAPP_ENABLED=false
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Test / Seed Data ──────────────────────────────────────────────────────────
# Phone number used by the seed script for test accounts
TEST_PHONE_NUMBER=9999999999
